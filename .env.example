# Variables de entorno para WFB Nómina CRM
# Copia este archivo como .env y configura tus valores

# Entorno (development/production)
NODE_ENV=production

# Puerto del servidor
PORT=3000

# Clave secreta para JWT (cambia esto por algo seguro)
JWT_SECRET=wfb_nomina_secret_2026_production

# Base de datos (para Railway será automática)
# DATABASE_URL=sqlite://./wfb_database.db